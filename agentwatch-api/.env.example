# Firebase Admin (service account JSON as one line, or path to file)
FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Email (optional)
